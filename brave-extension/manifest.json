{
  "manifest_version": 3,
  "name": "TorrentStream Magnet Catcher",
  "version": "1.0",
  "description": "Intercepts magnet: link clicks and forwards them to the TorrentStream-Local app.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
